# Copie ou renomeie o arquivo atual para .env
# Caso não use determinado recurso, pode remover as respectivas variáveis

### APLICAÇÃO ###

# O projeto cria o diretório /home/data e altera suas permissões. Caso configure sqlite, dê ctrl F e altere todas as referências.
ConnectionStrings__Sqlite=Data Source=/home/data/database.sqlite
ConnectionStrings__SqlServer=Server=YOUR_SERVER;Database=YOUR_DB;User Id=YOUR_USER;Password=YOUR_PASSWORD;TrustServerCertificate=True;
ConnectionStrings__SqlServerAdmin=Server=YOUR_SERVER;Database=YOUR_DB;User Id=YOUR_USER;Password=YOUR_PASSWORD;TrustServerCertificate=True;
ConnectionStrings__Redis=redis:6379

# Database: sqlserver, sqlite
FeatureFlags__Database=sqlserver
FeatureFlags__UseRedis=true

Hashids__Salt=SALT


### COMPOSE ###
MSSQL_SA_PASSWORD=YOUR_PASSWORD

# Containers serão habilitados dinamicamente. Deve ser separado por vírgula:
# Banco de dados: sqlserver ou sqlite
# Cache: memory ou redis
COMPOSE_PROFILES=sqlserver,redis